{
    "builds": [
        {
            "src": "api/orchestrator.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/api/spotify/(.*)",
            "dest": "api/orchestrator.py"
        },
        {
            "src": "/api/(.*)",
            "dest": "api/orchestrator.py"
        },
        {
            "src": "/",
            "dest": "api/orchestrator.py"
        }
    ]
}
